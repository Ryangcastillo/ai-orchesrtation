# AI Orchestration System Environment Variables

# Core Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# AI Provider Configuration
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vector Database Configuration
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=5432
VECTOR_DB_NAME=ai_orchestration
VECTOR_DB_USER=postgres
VECTOR_DB_PASSWORD=password

# Memory Configuration
MEMORY_COMPRESSION_THRESHOLD=100
CONTEXT_WINDOW_SIZE=30
ENABLE_SEMANTIC_SEARCH=true

# Security
JWT_SECRET=your_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# Plugin Configuration
PLUGIN_DIRECTORY=./plugins
ENABLE_HOT_RELOAD=true

# Market Adaptation
DEFAULT_SOPHISTICATION_LEVEL=3
ENABLE_MARKET_ADAPTATION=true

# Feature Flags
ENABLE_TRANSFORMATION_TRACKING=true
ENABLE_QUALITY_LOOPS=true
ENABLE_AUTOMATED_TESTING=true