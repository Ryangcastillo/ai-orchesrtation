{
  "name": "ai-orchestration",
  "version": "1.0.0",
  "description": "Modular AI Agent System for Easy Integration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "start": "node dist/index.js",
    "docker:build": "docker build -t ai-orchestration .",
    "docker:run": "docker run -p 3000:3000 ai-orchestration"
  },
  "keywords": [
    "ai",
    "agents",
    "orchestration",
    "modular",
    "plugins",
    "chatbot",
    "automation"
  ],
  "author": "Ryan Castillo",
  "license": "MIT",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "helmet": "^7.0.0",
    "joi": "^17.9.0",
    "lodash": "^4.17.21",
    "uuid": "^9.0.0",
    "winston": "^3.10.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
